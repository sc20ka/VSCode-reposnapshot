{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,  // Оставьте, но для any — типизируйте
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vscode", "mocha"]  // Добавьте vscode для API
  },
  "exclude": ["node_modules", "out", "manual-testing-sandbox"]
}